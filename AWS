<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AWS EC2 + Debian + SSH | Tutorial Futurista</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        :root {
            --bg-deep: #04060f;
            --bg-primary: #0a0d1a;
            --bg-card: rgba(12, 16, 30, 0.55);
            --bg-card-hover: rgba(16, 22, 42, 0.7);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-border-hover: rgba(255, 255, 255, 0.18);
            --text-primary: #e2e6f0;
            --text-secondary: #b0b8cc;
            --text-muted: #6b7394;
            --neon-blue: #4da8da;
            --neon-purple: #b44dda;
            --neon-cyan: #00e5ff;
            --debian-red: #d70a53;
            --accent-glow-blue: rgba(77, 168, 218, 0.5);
            --accent-glow-purple: rgba(180, 77, 218, 0.5);
            --accent-glow-cyan: rgba(0, 229, 255, 0.45);
            --nav-bg: rgba(8, 10, 22, 0.7);
            --nav-blur: 28px;
            --card-shadow: 0 12px 48px rgba(0, 0, 0, 0.55);
            --card-inner-glow: rgba(100, 160, 240, 0.06);
            --terminal-bg: rgba(6, 8, 18, 0.85);
            --terminal-header: rgba(20, 24, 40, 0.9);
            --terminal-text: #c8d6e5;
            --terminal-prompt: #4da8da;
            --section-glow: rgba(80, 140, 220, 0.03);
            --particle-color: 160, 200, 255;
            --particle-connection: rgba(140, 180, 240, 0.12);
            --bg-grid-opacity: 0.25;
            --btn-primary-bg: rgba(77, 168, 218, 0.2);
            --btn-primary-border: rgba(77, 168, 218, 0.5);
            --btn-primary-text: #4da8da;
            --error-card-bg: rgba(20, 8, 12, 0.7);
            --error-card-border: rgba(215, 10, 83, 0.3);
            --footer-bg: rgba(6, 8, 18, 0.8);
            --scrollbar-thumb: rgba(100, 140, 200, 0.3);
            --scrollbar-track: rgba(0, 0, 0, 0.4);
            --badge-bg: rgba(77, 168, 218, 0.15);
            --badge-text: #4da8da;
            --highlight-glow: rgba(77, 168, 218, 0.25);
            --icon-glow: drop-shadow(0 0 8px rgba(140, 180, 240, 0.6));
            --cmd-copy-bg: rgba(255, 255, 255, 0.04);
            --cmd-copy-hover: rgba(255, 255, 255, 0.1);
        }

        [data-theme="light"] {
            --bg-deep: #e8ecf2;
            --bg-primary: #f0f4f8;
            --bg-card: rgba(255, 255, 255, 0.6);
            --bg-card-hover: rgba(255, 255, 255, 0.78);
            --glass-border: rgba(0, 0, 0, 0.1);
            --glass-border-hover: rgba(0, 0, 0, 0.2);
            --text-primary: #1a1d2e;
            --text-secondary: #3d4258;
            --text-muted: #6e7594;
            --neon-blue: #2980b9;
            --neon-purple: #7d3cb5;
            --neon-cyan: #008fa0;
            --debian-red: #b80a44;
            --accent-glow-blue: rgba(41, 128, 185, 0.3);
            --accent-glow-purple: rgba(125, 60, 181, 0.3);
            --accent-glow-cyan: rgba(0, 143, 160, 0.3);
            --nav-bg: rgba(240, 244, 248, 0.75);
            --nav-blur: 28px;
            --card-shadow: 0 12px 48px rgba(0, 0, 0, 0.12);
            --card-inner-glow: rgba(60, 100, 180, 0.04);
            --terminal-bg: rgba(240, 242, 248, 0.88);
            --terminal-header: rgba(220, 224, 235, 0.9);
            --terminal-text: #1a1d2e;
            --terminal-prompt: #2980b9;
            --section-glow: rgba(60, 100, 180, 0.02);
            --particle-color: 60, 80, 140;
            --particle-connection: rgba(60, 80, 140, 0.08);
            --bg-grid-opacity: 0.1;
            --btn-primary-bg: rgba(41, 128, 185, 0.12);
            --btn-primary-border: rgba(41, 128, 185, 0.45);
            --btn-primary-text: #2980b9;
            --error-card-bg: rgba(255, 240, 240, 0.7);
            --error-card-border: rgba(184, 10, 68, 0.3);
            --footer-bg: rgba(230, 234, 240, 0.8);
            --scrollbar-thumb: rgba(80, 100, 150, 0.3);
            --scrollbar-track: rgba(0, 0, 0, 0.06);
            --badge-bg: rgba(41, 128, 185, 0.12);
            --badge-text: #2980b9;
            --highlight-glow: rgba(41, 128, 185, 0.18);
            --icon-glow: drop-shadow(0 0 6px rgba(60, 100, 160, 0.4));
            --cmd-copy-bg: rgba(0, 0, 0, 0.04);
            --cmd-copy-hover: rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            scrollbar-width: thin;
            scrollbar-color: var(--scrollbar-thumb) var(--scrollbar-track);
        }

        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: var(--scrollbar-track);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--scrollbar-thumb);
            border-radius: 3px;
        }

        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--bg-deep);
            color: var(--text-primary);
            overflow-x: hidden;
            cursor: none;
            transition: background-color 0.6s ease, color 0.6s ease;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        @media (max-width: 768px) {
            body {
                cursor: auto;
            }
        }

        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: 0.85;
            transition: opacity 0.6s ease;
        }

        [data-theme="light"] #particles-canvas {
            opacity: 0.55;
        }

        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: var(--bg-grid-opacity);
            background-image:
                linear-gradient(rgba(100, 140, 200, 0.12) 1px, transparent 1px),
                linear-gradient(90deg, rgba(100, 140, 200, 0.12) 1px, transparent 1px);
            background-size: 60px 60px;
            background-position: center;
            transition: opacity 0.6s ease;
            mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 70%);
            -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 70%);
        }

        .custom-cursor {
            position: fixed;
            top: 0;
            left: 0;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            pointer-events: none;
            z-index: 99999;
            border: 1.5px solid var(--neon-cyan);
            background: transparent;
            mix-blend-mode: difference;
            transition: width 0.25s ease, height 0.25s ease, border-color 0.25s ease, background 0.25s ease;
            box-shadow: 0 0 18px var(--accent-glow-cyan), 0 0 40px rgba(0, 229, 255, 0.25);
            transform: translate(-50%, -50%);
        }
        .custom-cursor-dot {
            position: fixed;
            top: 0;
            left: 0;
            width: 5px;
            height: 5px;
            border-radius: 50%;
            pointer-events: none;
            z-index: 99999;
            background: var(--neon-cyan);
            box-shadow: 0 0 12px var(--neon-cyan), 0 0 30px rgba(0, 229, 255, 0.7);
            transform: translate(-50%, -50%);
            transition: width 0.15s ease, height 0.15s ease;
        }
        .custom-cursor.hover {
            width: 50px;
            height: 50px;
            background: rgba(0, 229, 255, 0.1);
            border-color: var(--neon-purple);
            box-shadow: 0 0 30px var(--accent-glow-purple), 0 0 60px rgba(180, 77, 218, 0.3);
            mix-blend-mode: normal;
        }
        .custom-cursor-dot.hover {
            width: 8px;
            height: 8px;
            background: #fff;
            box-shadow: 0 0 20px #fff, 0 0 40px rgba(255, 255, 255, 0.8);
        }

        @media (max-width: 768px) {
            .custom-cursor,
            .custom-cursor-dot {
                display: none;
            }
        }

        #loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 100000;
            background: #020308;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            transition: opacity 0.7s ease, visibility 0.7s ease;
            font-family: 'JetBrains Mono', monospace;
        }
        #loading-screen.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        #loading-terminal {
            width: 90%;
            max-width: 600px;
            background: rgba(6, 8, 18, 0.95);
            border: 1px solid rgba(0, 229, 255, 0.3);
            border-radius: 12px;
            padding: 28px 24px;
            box-shadow: 0 0 60px rgba(0, 229, 255, 0.2), 0 20px 60px rgba(0, 0, 0, 0.8);
            position: relative;
            overflow: hidden;
        }
        #loading-terminal::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(from 0deg, transparent, rgba(0, 229, 255, 0.04), transparent, rgba(180, 77, 218, 0.04), transparent);
            animation: loadingRotate 8s linear infinite;
            z-index: 0;
        }
        @keyframes loadingRotate {
            to {
                transform: rotate(360deg);
            }
        }
        #loading-terminal .term-content {
            position: relative;
            z-index: 1;
        }
        #loading-terminal .log-line {
            color: #6b9;
            font-size: 13px;
            margin-bottom: 6px;
            opacity: 0;
            animation: logFadeIn 0.3s forwards;
            letter-spacing: 0.5px;
        }
        @keyframes logFadeIn {
            to {
                opacity: 1;
            }
        }
        #loading-terminal .log-line .prompt {
            color: #4da8da;
        }
        #loading-terminal .log-line .highlight {
            color: #00e5ff;
        }
        #loading-progress-bar {
            width: 100%;
            height: 2px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 2px;
            margin-top: 16px;
            overflow: hidden;
            position: relative;
            z-index: 1;
        }
        #loading-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #4da8da, #00e5ff, #b44dda);
            border-radius: 2px;
            width: 0%;
            transition: width 0.3s ease;
            box-shadow: 0 0 12px rgba(0, 229, 255, 0.7);
            animation: progressPulse 1.5s ease-in-out infinite;
        }
        @keyframes progressPulse {
            0%,
            100% {
                box-shadow: 0 0 12px rgba(0, 229, 255, 0.7);
            }
            50% {
                box-shadow: 0 0 24px rgba(0, 229, 255, 1), 0 0 40px rgba(180, 77, 218, 0.6);
            }
        }
        #loading-title {
            color: #e2e6f0;
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 18px;
            position: relative;
            z-index: 1;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-align: center;
        }

        nav {
            position: fixed;
            top: 16px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1000;
            background: var(--nav-bg);
            backdrop-filter: blur(var(--nav-blur));
            -webkit-backdrop-filter: blur(var(--nav-blur));
            border: 1px solid var(--glass-border);
            border-radius: 50px;
            padding: 10px 24px;
            display: flex;
            align-items: center;
            gap: 22px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
            transition: all 0.5s ease;
            max-width: 95vw;
            flex-wrap: nowrap;
            overflow-x: auto;
        }
        nav.scrolled {
            top: 6px;
            padding: 8px 20px;
            gap: 16px;
            border-radius: 40px;
            background: rgba(8, 10, 22, 0.9);
            box-shadow: 0 8px 50px rgba(0, 0, 0, 0.7);
        }
        [data-theme="light"] nav.scrolled {
            background: rgba(240, 244, 248, 0.9);
        }
        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.4px;
            transition: color 0.3s ease, text-shadow 0.3s ease;
            white-space: nowrap;
            position: relative;
            padding: 4px 0;
            cursor: none;
        }
        nav a:hover,
        nav a.active {
            color: var(--neon-cyan);
            text-shadow: 0 0 12px var(--accent-glow-cyan);
        }
        nav a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 1.5px;
            background: var(--neon-cyan);
            transition: width 0.3s ease;
            box-shadow: 0 0 8px var(--accent-glow-cyan);
        }
        nav a.active::after,
        nav a:hover::after {
            width: 100%;
        }
        .nav-toggle-theme {
            background: none;
            border: 1px solid var(--glass-border);
            color: var(--text-secondary);
            cursor: none;
            font-size: 1rem;
            padding: 8px;
            border-radius: 50%;
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.35s ease;
            flex-shrink: 0;
        }
        .nav-toggle-theme:hover {
            border-color: var(--neon-purple);
            color: var(--neon-purple);
            box-shadow: 0 0 20px var(--accent-glow-purple);
        }
        .nav-mobile-toggle {
            display: none;
            background: none;
            border: 1px solid var(--glass-border);
            color: var(--text-primary);
            font-size: 1.3rem;
            cursor: none;
            padding: 6px 10px;
            border-radius: 50%;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }
        @media (max-width: 768px) {
            nav {
                gap: 8px;
                padding: 8px 14px;
                border-radius: 30px;
                top: 10px;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                justify-content: flex-start;
            }
            nav a {
                font-size: 0.72rem;
                letter-spacing: 0.2px;
            }
            .nav-mobile-toggle {
                display: flex;
                cursor: pointer;
            }
            .nav-toggle-theme {
                cursor: pointer;
            }
            nav a {
                cursor: pointer;
            }
        }
        .mobile-menu-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 999;
            background: rgba(4, 6, 15, 0.92);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 28px;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        .mobile-menu-overlay.open {
            opacity: 1;
            visibility: visible;
        }
        .mobile-menu-overlay a {
            color: var(--text-primary);
            text-decoration: none;
            font-size: 1.4rem;
            font-weight: 600;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .mobile-menu-overlay a:hover {
            color: var(--neon-cyan);
            text-shadow: 0 0 20px var(--accent-glow-cyan);
        }
        .mobile-menu-close {
            position: absolute;
            top: 24px;
            right: 24px;
            background: none;
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: #fff;
            font-size: 1.5rem;
            padding: 10px 16px;
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .mobile-menu-close:hover {
            border-color: var(--debian-red);
            color: var(--debian-red);
            box-shadow: 0 0 20px rgba(215, 10, 83, 0.5);
        }

        main {
            position: relative;
            z-index: 1;
            pointer-events: auto;
        }

        section {
            position: relative;
            z-index: 1;
            padding: 80px 24px;
            max-width: 1100px;
            margin: 0 auto;
            pointer-events: auto;
        }
        @media (max-width: 768px) {
            section {
                padding: 50px 16px;
            }
        }

        #hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding-top: 100px;
            position: relative;
        }
        #hero .hero-badge {
            display: inline-block;
            background: var(--badge-bg);
            color: var(--badge-text);
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 3px;
            padding: 8px 20px;
            border-radius: 50px;
            border: 1px solid rgba(77, 168, 218, 0.3);
            margin-bottom: 28px;
            text-transform: uppercase;
            animation: fadeInUp 1s ease forwards;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        #hero h1 {
            font-size: clamp(2.8rem, 6vw, 5.5rem);
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.05;
            background: linear-gradient(135deg, #e2e6f0 0%, #4da8da 30%, #b44dda 60%, #00e5ff 85%, #e2e6f0 100%);
            background-size: 300% 300%;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradientShift 6s ease infinite, fadeInUp 1s ease 0.15s forwards;
            opacity: 0;
            animation-fill-mode: forwards;
            filter: drop-shadow(0 0 30px rgba(140, 180, 240, 0.4));
        }
        @keyframes gradientShift {
            0%,
            100% {
                background-position: 0% 50%;
            }
            25% {
                background-position: 100% 0%;
            }
            50% {
                background-position: 100% 100%;
            }
            75% {
                background-position: 0% 100%;
            }
        }
        #hero .hero-subtitle {
            font-size: clamp(1rem, 1.8vw, 1.35rem);
            color: var(--text-secondary);
            margin-top: 18px;
            letter-spacing: 0.5px;
            font-weight: 400;
            max-width: 650px;
            animation: fadeInUp 1s ease 0.3s forwards;
            opacity: 0;
            animation-fill-mode: forwards;
        }
        #hero .hero-buttons {
            display: flex;
            gap: 16px;
            margin-top: 36px;
            flex-wrap: wrap;
            justify-content: center;
            animation: fadeInUp 1s ease 0.45s forwards;
            opacity: 0;
            animation-fill-mode: forwards;
        }
        .btn {
            padding: 14px 28px;
            border-radius: 50px;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.6px;
            text-decoration: none;
            cursor: none;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            border: 1.5px solid transparent;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        @media (max-width: 768px) {
            .btn {
                cursor: pointer;
                padding: 12px 22px;
                font-size: 0.8rem;
            }
        }
        .btn-primary {
            background: var(--btn-primary-bg);
            border-color: var(--btn-primary-border);
            color: var(--btn-primary-text);
            box-shadow: 0 0 30px rgba(77, 168, 218, 0.2);
        }
        .btn-primary:hover {
            background: rgba(77, 168, 218, 0.3);
            border-color: rgba(77, 168, 218, 0.8);
            box-shadow: 0 0 50px rgba(77, 168, 218, 0.45), 0 0 80px rgba(0, 229, 255, 0.25);
            transform: translateY(-3px);
        }
        .btn-secondary {
            background: transparent;
            border-color: rgba(180, 77, 218, 0.45);
            color: var(--text-primary);
            box-shadow: 0 0 20px rgba(180, 77, 218, 0.1);
        }
        .btn-secondary:hover {
            border-color: rgba(180, 77, 218, 0.8);
            box-shadow: 0 0 40px rgba(180, 77, 218, 0.35);
            transform: translateY(-3px);
        }
        .btn i {
            font-size: 0.85rem;
        }

        .section-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--neon-cyan);
            margin-bottom: 14px;
            position: relative;
        }
        .section-label::before {
            content: '';
            width: 20px;
            height: 1px;
            background: var(--neon-cyan);
            box-shadow: 0 0 6px var(--accent-glow-cyan);
        }
        .section-title {
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
            color: var(--text-primary);
        }
        .section-desc {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 36px;
            max-width: 600px;
            line-height: 1.6;
        }

        .card {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 28px;
            box-shadow: var(--card-shadow);
            transition: all 0.5s ease;
            position: relative;
            overflow: hidden;
            cursor: none;
        }
        @media (max-width: 768px) {
            .card {
                cursor: default;
                padding: 20px;
                border-radius: 16px;
            }
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), var(--card-inner-glow), transparent 50%);
            pointer-events: none;
            z-index: 0;
            opacity: 0;
            transition: opacity 0.4s ease;
